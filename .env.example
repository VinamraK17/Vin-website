# ── Contact Details ────────────────────────────────────────────────────────────
CONTACT_EMAIL=contact@vinamrakumar.com
CONTACT_PHONE=+41 XX XXX XX XX

# ── MariaDB Credentials (used by Docker Compose) ────────────────────────────
MARIADB_ROOT_PASSWORD=change_me_strong_password
MARIADB_DATABASE=portfolio
MARIADB_USER=portfolio_user
MARIADB_PASSWORD=change_me_strong_password

# ── Database URL (used by Prisma / Node server) ─────────────────────────────
# If your password contains @ or special chars, URL-encode them first:
#   @ → %40   # → %23   $ → %24
DATABASE_URL=mysql://portfolio_user:change_me_strong_password@portfolio-db:3306/portfolio

# ── SMTP (optional — Synology MailPlus or any SMTP relay) ───────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
